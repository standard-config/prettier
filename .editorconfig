root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = tab
insert_final_newline = true
max_line_length = 80
trim_trailing_whitespace = true

[*.{css,scss}]
max_line_length = 100

[*.{html,htm}]
max_line_length = 100

[*.{md,mdx}]
indent_style = space

[*.{sh,bash,zsh}]
indent_size = 2
indent_style = space

[*.{yaml,yml}]
indent_size = 2
indent_style = space
